    #tvPqAYCC4VXdfNmtEgvnpNID ^"Chain shirt" DEF {
        EXTENDS ^"Armor"
        PROPERTIES {
            ^"Category" STRING "Medium Armor"
            ^"Cost" DEF {
                ^"Amount" INTEGER 50
                ^"Unit" STRING "gp"
            }
            ^"Base Armor Class" INTEGER 13
            ^"Adds Dex Modifier" BOOLEAN true
            ^"Dex Modifier Max" INTEGER 2
            ^"Weight" STRING "20 lb."
            ^"Description" STRING "Made of interlocking metal rings, a chain shirt is worn between layers of clothing or leather. This armor offers modest protection to the wearer's upper body and allows the sound of the rings rubbing against one another to be muffled by outer layers."
        }
    }
    #twUDSfUdYA4AvPA65aGHZg5E ^"Scale mail" DEF {
        EXTENDS ^"Armor"
        PROPERTIES {
            ^"Category" STRING "Medium Armor"
            ^"Cost" DEF {
                ^"Amount" INTEGER 50
                ^"Unit" STRING "gp"
            }
            ^"Base Armor Class" INTEGER 14
            ^"Adds Dex Modifier" BOOLEAN true
            ^"Dex Modifier Max" INTEGER 2
            ^"Stealth Disadvantage" BOOLEAN true
            ^"Weight" STRING "45 lb."
            ^"Description" STRING "This armor consists of a coat and leggings (and perhaps a separate skirt) of leather covered with overlapping pieces of metal, much like the scales of a fish. The suit includes gauntlets."
        }
    }
    #tcOr3di2oZ7sGTOWdVzwkarA ^"Breastplate" DEF {
        EXTENDS ^"Armor"
        PROPERTIES {
            ^"Category" STRING "Medium Armor"
            ^"Cost" DEF {
                ^"Amount" INTEGER 400
                ^"Unit" STRING "gp"
            }
            ^"Base Armor Class" INTEGER 14
            ^"Adds Dex Modifier" BOOLEAN true
            ^"Dex Modifier Max" INTEGER 2
            ^"Weight" STRING "20 lb."
