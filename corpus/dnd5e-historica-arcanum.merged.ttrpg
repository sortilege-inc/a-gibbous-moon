    #toZfs6XQusSdGMdXJGoJ5Ylx ^"Oathbow" DEF {
        EXTENDS ^"Magic Item"
        PROPERTIES {
            ^"Item Type" STRING "Weapon (longbow)"
            ^"Rarity" STRING "very rare"
            ^"Requires Attunement" BOOLEAN true
