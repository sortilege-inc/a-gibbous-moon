    #tQaHpTidJVkolgQ6MXMxolOQ ^"Bostanji" DEF {
        EXTENDS ^"Monster"
        PROPERTIES {
            ^"Name" STRING "Bostanji"
            ^"Size" STRING "medium"
            ^"Type" STRING "humanoid (human)"
            ^"Alignment" STRING "any lawful alignment"
            ^"Abilities" DEF {
                ^"Strength" INTEGER 19
                ^"Dexterity" INTEGER 16
                ^"Constitution" INTEGER 14
