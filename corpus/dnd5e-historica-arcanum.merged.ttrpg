            ^"Adds Dex Modifier" BOOLEAN true
            ^"Dex Modifier Max" INTEGER 0
            ^"Stealth Disadvantage" BOOLEAN true
            ^"Weight" STRING "8 lb."
            ^"Description" STRING "Padded armor consists of quilted layers of cloth and batting."
