            ^"At Higher Levels" STRING "When you cast this spell using a spell slot of 2nd level or higher, you can target one additional creature for each slot level above 1st."
            ^"Classes" LIST OF STRING ["Bard", "Paladin"]
        }
    }
    #tktYhgwOB3Uj5NXCtvUkORIS ^"Hideous Laughter" DEF {
        EXTENDS ^"Spell"
        PROPERTIES {
            ^"Level" INTEGER 1
            ^"School" STRING "Enchantment"
