            ^"Adds Dex Modifier" BOOLEAN true
            ^"Dex Modifier Max" INTEGER 2
            ^"Weight" STRING "12 lb."
            ^"Description" STRING "This crude armor consists of thick furs and pelts. It is commonly worn by barbarian tribes, evil humanoids, and other folk who lack access to the tools and materials needed to create better armor."
