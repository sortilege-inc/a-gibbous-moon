            ^"Duration" STRING "8 hours"
            ^"Description" STRING "You touch a willing creature to grant it the ability to see in the dark. For the duration, that creature has darkvision out to a range of 60 feet."
            ^"Classes" LIST OF STRING ["Druid", "Ranger", "Sorcerer", "Wizard"]
        }
    }
    #tc5BKfji75df4cyfCAksIt58 ^"Daylight" DEF {
        EXTENDS ^"Spell"
        PROPERTIES {
            ^"Level" INTEGER 3
