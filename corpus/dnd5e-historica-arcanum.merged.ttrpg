        RANKS {
            #tA24WGcDqSQAVQWK8i9QpLyP ^"Apprentice Antiquarian" DEF {
                EXTENDS ^"Profession Rank"
                ^"Rank Number"
                INTEGER 1
                ^"Description"
                STRING "As an apprentice antiquarian, you have basic knowledge about the workings of enchanted items; you will have to choose one innovations from below:

You can advance into the Journeyman level after taking at least two Apprentice level innovations. Each innovation will cost you 50 PEX."
                PERKS {
                    #t5IING7ZYMEf746V90pDMrbY ^"Unmask the Hidden" DEF {
                        EXTENDS ^"Profession Perk"
                        ^"PEX Cost"
                        INTEGER 50
                        ^"Description"
                        STRING "The antiquarian knows how to detect the enchanted auras of magical objects and how to identify their properties. The antiquarian gains the ability to use detect magic and identify spells only as rituals."
                    }
