    #tvck2nVUboFR3zipckiCmu2n ^"Helm of Brilliance" DEF {
        EXTENDS ^"Magic Item"
        PROPERTIES {
            ^"Item Type" STRING "Wondrous item"
            ^"Rarity" STRING "very rare"
