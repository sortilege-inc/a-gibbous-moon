    #tDkwpU4pfNzmpLG4vx4i2bzO ^"Clone" DEF {
        EXTENDS ^"Spell"
        PROPERTIES {
            ^"Level" INTEGER 8
            ^"School" STRING "Necromancy"
            ^"Casting Time" STRING "1 hour"
            ^"Range" STRING "Touch"
            ^"Components" STRING "V, S, M (a diamond worth at least 1,000 gp and at least 1 cubic inch of flesh of the creature that is to be cloned, which the spell consumes, and a vessel worth at least 2,000 gp that has a sealable lid and is large enough to hold a Medium creature, such as a huge urn, coffin, mud-filled cyst in the ground, or crystal container filled with salt water)"
            ^"Duration" STRING "Instantaneous"
            ^"Description" STRING "This spell grows an inert duplicate of a living creature as a safeguard against death. This clone forms inside a sealed vessel and grows to full size and maturity after 120 days; you can also choose to have the clone be a younger version of the same creature. It remains inert and endures indefinitely, as long as its vessel remains undisturbed. At any time after the clone matures, if the original creature dies, its soul transfers to the clone, provided that the soul is free and willing to return. The clone is physically identical to the original and has the same personality, memories, and abilities, but none of the original’s equipment. The original creature’s physical remains, if they still exist, become inert and can’t thereafter be restored to life, since the creature’s soul is elsewhere."
            ^"Classes" LIST OF STRING ["Wizard"]
        }
    }
    #tOoPFkECVMAqwjUBRQOuCEU4 ^"Cloudkill" DEF {
        EXTENDS ^"Spell"
        PROPERTIES {
            ^"Level" INTEGER 5
            ^"School" STRING "Conjuration"
            ^"Casting Time" STRING "1 action"
            ^"Range" STRING "120 feet"
            ^"Components" STRING "V, S"
            ^"Duration" STRING "Concentration, up to 10 minutes"
            ^"Concentration" BOOLEAN true
            ^"Description" STRING "You create a 20-foot-radius sphere of poisonous, yellow-green fog centered on a point you choose within range. The fog spreads around corners. It lasts for the duration or until strong wind disperses the fog, ending the spell. Its area is heavily obscured. When a creature enters the spell’s area for the first time on a turn or starts its turn there, that creature must make a Constitution saving throw. The creature takes 5d8 poison damage on a failed save, or half as much damage on a successful one.

Creatures are affected even if they hold their breath or don’t need to breathe. The fog moves 10 feet away from you at the start of each of your turns, rolling along the surface of the ground. The vapors, being heavier than air, sink to the lowest level of the land, even pouring down openings."
            ^"At Higher Levels" STRING "When you cast this spell using a spell slot of 6th level or higher, the damage increases by 1d8 for each slot level above 5th."
            ^"Classes" LIST OF STRING ["Sorcerer", "Wizard"]
        }
    }
    #tshAN39d5KS15g3BiqjRgsCY ^"Color Spray" DEF {
        EXTENDS ^"Spell"
        PROPERTIES {
            ^"Level" INTEGER 1
            ^"School" STRING "Illusion"
            ^"Casting Time" STRING "1 action"
            ^"Range" STRING "Self (15-foot cone)"
            ^"Components" STRING "V, S, M (a pinch of powder or sand that is colored red, yellow, and blue)"
            ^"Duration" STRING "1 round"
            ^"Description" STRING "A dazzling array of flashing, colored light springs from your hand. Roll 6d10; the total is how many hit points of creatures this spell can effect. Creatures in a 15-foot cone originating from you are affected in ascending order of their current hit points (ignoring unconscious creatures and creatures that can’t see). Starting with the creature that has the lowest current hit points, each creature affected by this spell is blinded until the spell ends. Subtract each creature’s hit points from the total before moving on to the creature with the next lowest hit points. A creature’s hit points must be equal to or less than the remaining total for that creature to be affected."
            ^"At Higher Levels" STRING "When you cast this spell using a spell slot of 2nd level or higher, roll an additional 2d10 for each slot level above 1st."
            ^"Classes" LIST OF STRING ["Sorcerer", "Wizard"]
        }
    }
    #tVC5ZvOHY0GnKs16u6PAGOMo ^"Command" DEF {
        EXTENDS ^"Spell"
        PROPERTIES {
            ^"Level" INTEGER 1
            ^"School" STRING "Enchantment"
            ^"Casting Time" STRING "1 action"
            ^"Range" STRING "60 feet"
            ^"Components" STRING "V"
            ^"Duration" STRING "1 round"
            ^"Description" STRING "You speak a one-word command to a creature you can see within range. The target must succeed on a Wisdom saving throw or follow the command on its next turn. The spell has no effect if the target is undead, if it doesn’t understand your language, or if your command is directly harmful to it. Some typical commands and their effects follow. You might issue a command other than one described here. If you do so, the GM determines how

the target behaves. If the target can’t follow your command, the spell ends. **Approach.** The target moves toward you by the shortest and most direct route, ending its turn if it moves within 5 feet of you. **Drop.** The target drops whatever it is holding and then ends its turn. **Flee.** The target spends its turn moving away from you by the fastest available means. **Grovel.** The target falls prone and then ends its turn. **Halt.** The target doesn’t move and takes no actions. A flying creature stays aloft, provided that it is able to do so. If it must move to stay aloft, it flies the minimum distance needed to remain in the air."
            ^"At Higher Levels" STRING "When you cast this spell using a spell slot of 2nd level or higher, you can affect one additional creature for each slot level above 1st. The creatures must be within 30 feet of each other when you target them."
            ^"Classes" LIST OF STRING ["Cleric", "Paladin"]
        }
    }
    #tThUwtAlwzg6nZNRM8qL8TRh ^"Commune" DEF {
        EXTENDS ^"Spell"
        PROPERTIES {
            ^"Level" INTEGER 5
            ^"School" STRING "Divination"
            ^"Casting Time" STRING "1 minute"
            ^"Range" STRING "Self"
            ^"Components" STRING "V, S, M (incense and a vial of holy or unholy water)"
            ^"Duration" STRING "1 minute"
            ^"Ritual" BOOLEAN true
            ^"Description" STRING "You contact your deity or a divine proxy and ask up to three questions that can be answered with a yes or no. You must ask your questions before the spell ends. You receive a correct answer for each question. Divine beings aren’t necessarily omniscient, so you might receive “unclear” as an answer if a question pertains to information that lies beyond the deity’s knowledge. In a case where a one-word answer could be misleading or contrary to the deity’s interests, the GM might offer a short phrase as an answer instead. If you cast the spell two or more times before finishing your next long rest, there is a cumulative 25 percent chance for each casting after the first that you get no answer. The GM makes this roll in secret."
            ^"Classes" LIST OF STRING ["Cleric"]
        }
    }
    #tj8w2GltizGEHcc5oIMWL982 ^"Commune with Nature" DEF {
        EXTENDS ^"Spell"
        PROPERTIES {
            ^"Level" INTEGER 5
            ^"School" STRING "Divination"
            ^"Casting Time" STRING "1 minute"
            ^"Range" STRING "Self"
            ^"Components" STRING "V, S"
            ^"Duration" STRING "Instantaneous"
            ^"Ritual" BOOLEAN true
            ^"Description" STRING "You briefly become one with nature and gain knowledge of the surrounding territory. In the outdoors, the spell gives you knowledge of the land within 3 miles of you. In caves and other natural underground settings, the radius is limited to 300 feet. The spell doesn’t function where nature has been replaced by construction, such as in dungeons and towns. You instantly gain knowledge of up to three facts of your choice about any of the following subjects as they relate to the area:

• terrain and bodies of water • prevalent plants, minerals, animals, or peoples • powerful celestials, fey, fiends, elementals, or undead • influence from other planes of existence • buildings For example, you could determine the location of powerful undead in the area, the location of major sources of safe drinking water, and the location of any nearby towns."
            ^"Classes" LIST OF STRING ["Druid", "Ranger"]
        }
    }
    #t2tkZkgaRLe8BIUsA5dtkPcb ^"Comprehend Languages" DEF {
        EXTENDS ^"Spell"
        PROPERTIES {
            ^"Level" INTEGER 1
            ^"School" STRING "Divination"
            ^"Casting Time" STRING "1 action"
            ^"Range" STRING "Self"
            ^"Components" STRING "V, S, M (a pinch of soot and salt)"
            ^"Duration" STRING "1 hour"
            ^"Ritual" BOOLEAN true
            ^"Description" STRING "For the duration, you understand the literal meaning of any spoken language that you hear. You also understand any written language that you see, but you must be touching the surface on which the words are written. It takes about 1 minute to read one page of text. This spell doesn’t decode secret messages in a text or a glyph, such as an arcane sigil, that isn’t part of a written language."
            ^"Classes" LIST OF STRING ["Bard", "Sorcerer", "Warlock", "Wizard"]
        }
    }
    #tiDK8Ys8z9q5x3MgdGHwrTlS ^"Compulsion" DEF {
        EXTENDS ^"Spell"
        PROPERTIES {
            ^"Level" INTEGER 4
            ^"School" STRING "Enchantment"
            ^"Casting Time" STRING "1 action"
            ^"Range" STRING "30 feet"
            ^"Components" STRING "V, S"
            ^"Duration" STRING "Concentration, up to 1 minute"
            ^"Concentration" BOOLEAN true
            ^"Description" STRING "Creatures of your choice that you can see within range and that can hear you must make a Wisdom saving throw. A target automatically succeeds on this saving throw if it can't be charmed. On a failed save, a target is affected by this spell. Until the spell ends, you can use a bonus action on each of your turns to designate a direction that is horizontal to

you. Each affected target must use as much of its movement as possible to move in that direction on its next turn. It can take its action before it moves. After moving in this way, it can make another Wisdom saving to try to end the effect. A target isn't compelled to move into an obviously deadly hazard, such as a fire or pit, but it will provoke opportunity attacks to move in the designated direction."
            ^"Classes" LIST OF STRING ["Bard"]
        }
    }
