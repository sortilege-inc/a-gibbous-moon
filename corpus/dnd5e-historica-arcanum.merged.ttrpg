    #tOO3UZJSFz2o7xHDTKaloPqw ^"Spirit Guardians" DEF {
        EXTENDS ^"Spell"
        PROPERTIES {
            ^"Level" INTEGER 3
            ^"School" STRING "Conjuration"
            ^"Casting Time" STRING "1 action"
            ^"Range" STRING "Self (15-foot radius)"
            ^"Components" STRING "V, S, M (a holy symbol)"
            ^"Duration" STRING "Concentration, up to 10 minutes"
            ^"Concentration" BOOLEAN true
            ^"Description" STRING "You call forth spirits to protect you. They flit around you to a distance of 15 feet for the duration. If you are good or neutral, their spectral form appears angelic or fey (your choice). If you are evil, they appear fiendish. When you cast this spell, you can designate any number of creatures you can see to be unaffected by it. An affected creature’s speed is halved in the area, and when the creature enters the area for the first time on a turn or starts its turn there, it must make a Wisdom saving throw. On a failed save, the creature takes 3d8 radiant damage (if you are good or neutral) or 3d8 necrotic damage (if you are evil). On a successful save, the creature takes half as much damage."
            ^"At Higher Levels" STRING "When you cast this spell using a spell slot of 4th level or higher, the damage increases by 1d8 for each slot level above 3rd."
            ^"Classes" LIST OF STRING ["Cleric"]
        }
    }
    #t7fgVfnZJBIrupawiUjXsZyh ^"Spiritual Weapon" DEF {
        EXTENDS ^"Spell"
        PROPERTIES {
            ^"Level" INTEGER 2
            ^"School" STRING "Evocation"
            ^"Casting Time" STRING "1 bonus action"
            ^"Range" STRING "60 feet"
            ^"Components" STRING "V, S"
            ^"Duration" STRING "1 minute"
            ^"Description" STRING "You create a floating, spectral weapon within range that lasts for the duration or until you cast this spell again. When you cast the spell, you can make a melee spell attack against a creature within 5 feet of the weapon. On a hit, the target takes force damage equal to 1d8 + your spellcasting ability modifier. As a bonus action on your turn, you can move the weapon up to 20 feet and repeat the attack against a creature within 5 feet of it. The weapon can take whatever form you choose. Clerics of deities who are associated with a particular weapon (as St. Cuthbert is known for his mace and Thor for his hammer) make this spell’s effect resemble that weapon."
            ^"At Higher Levels" STRING "When you cast this spell using a spell slot of 3rd level or higher, the damage increases by 1d8 for every two slot levels above 2nd."
            ^"Classes" LIST OF STRING ["Cleric"]
        }
    }
    #tUGwrzgcU38lRELh39WajHtS ^"Stinking Cloud" DEF {
        EXTENDS ^"Spell"
        PROPERTIES {
            ^"Level" INTEGER 3
            ^"School" STRING "Conjuration"
            ^"Casting Time" STRING "1 action"
            ^"Range" STRING "90 feet"
            ^"Components" STRING "V, S, M (a rotten egg or several skunk cabbage leaves)"
            ^"Duration" STRING "Concentration, up to 1 minute"
            ^"Concentration" BOOLEAN true
            ^"Description" STRING "You create a 20-foot-radius sphere of yellow, nauseating gas centered on a point within range. The cloud spreads around corners, and its area is heavily obscured. The cloud lingers in the air for the duration. Each creature that is completely within the cloud at the start of its turn must make a Constitution saving throw against poison. On a failed save, the creature spends its action that turn retching and reeling. Creatures that don’t need to breathe or are immune to poison automatically succeed on this saving throw.

A moderate wind (at least 10 miles per hour) disperses the cloud after 4 rounds. A strong wind (at least 20 miles per hour) disperses it after 1 round."
            ^"Classes" LIST OF STRING ["Bard", "Sorcerer", "Wizard"]
        }
    }
    #trKuOrjcX2bdAI88qAhr4m7d ^"Stone Shape" DEF {
        EXTENDS ^"Spell"
        PROPERTIES {
            ^"Level" INTEGER 4
            ^"School" STRING "Transmutation"
            ^"Casting Time" STRING "1 action"
            ^"Range" STRING "Touch"
            ^"Components" STRING "V, S, M (soft clay, which must be worked into roughly the desired shape of the stone object)"
            ^"Duration" STRING "Instantaneous"
            ^"Description" STRING "You touch a stone object of Medium size or smaller or a section of stone no more than 5 feet in any dimension and form it into any shape that suits your purpose. So, for example, you could shape a large rock into a weapon, idol, or coffer, or make a small passage through a wall, as long as the wall is less than 5 feet thick. You could also shape a stone door or its frame to seal the door shut. The object you create can have up to two hinges and a latch, but finer mechanical detail isn’t possible."
            ^"Classes" LIST OF STRING ["Cleric", "Druid", "Wizard"]
        }
    }
    #tD5OD5qwphosLY6KUJ97CjBf ^"Stoneskin" DEF {
        EXTENDS ^"Spell"
        PROPERTIES {
            ^"Level" INTEGER 4
            ^"School" STRING "Abjuration"
            ^"Casting Time" STRING "1 action"
