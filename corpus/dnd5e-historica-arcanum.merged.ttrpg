    #t0UuEGyzyjbMCUmt97nNAsox ^"Nazar, the Evil Eye" DEF {
        EXTENDS ^"Spell"
        PROPERTIES {
            ^"Level" INTEGER 2
            ^"School" STRING "Enchantment"
            ^"Casting Time" STRING "1 action"
            ^"Range" STRING "30 ft."
            ^"Components" STRING "S"
