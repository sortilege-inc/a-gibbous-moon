    #thdH9FitC1skOlzsc5GkyK4o ^"Sword of Wounding" DEF {
        EXTENDS ^"Magic Item"
        PROPERTIES {
            ^"Item Type" STRING "Weapon (any sword)"
            ^"Rarity" STRING "rare"
            ^"Requires Attunement" BOOLEAN true
