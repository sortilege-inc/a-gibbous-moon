            ^"Concentration" BOOLEAN true
            ^"Description" STRING "A creature of your choice that you can see within range perceives everything as hilariously funny and falls into fits of laughter if this spell affects it. The target must succeed on a Wisdom saving throw or fall prone, becoming incapacitated and unable to stand up for the duration. A creature with an Intelligence score of 4 or less isn’t affected. At the end of each of its turns, and each time it takes damage, the target can make another Wisdom saving throw. The target has advantage on the saving throw if it’s triggered by damage. On a success, the spell ends."
            ^"Classes" LIST OF STRING ["Bard", "Wizard"]
        }
    }
    #tXQFHW1Xa1FQRlqBRJNOdWtc ^"Hold Monster" DEF {
        EXTENDS ^"Spell"
        PROPERTIES {
            ^"Level" INTEGER 5
            ^"School" STRING "Enchantment"
            ^"Casting Time" STRING "1 action"
            ^"Range" STRING "90 feet"
            ^"Components" STRING "V, S, M (a small, straight piece of iron)"
            ^"Duration" STRING "Concentration, up to 1 minute"
            ^"Concentration" BOOLEAN true
