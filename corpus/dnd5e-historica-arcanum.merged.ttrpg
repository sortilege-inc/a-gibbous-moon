            }
            ^"Base Armor Class" INTEGER 11
            ^"Adds Dex Modifier" BOOLEAN true
            ^"Dex Modifier Max" INTEGER 0
            ^"Weight" STRING "10 lb."
            ^"Description" STRING "The breastplate and shoulder protectors of this armor are made of leather that has been stiffened by being boiled in oil. The rest of the armor is made of softer and more flexible materials."
