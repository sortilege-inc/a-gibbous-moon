                        EXTENDS ^"Profession Perk"
                        ^"PEX Cost"
                        INTEGER 50
                        ^"Description"
                        STRING "The antiquarian is well versed in the workings of magical objects. Attunement is a lot easier for an antiquarian than other people. The antiquarian can attune to a magical object within the same short rest that the item has been identified."
                    }
                }
